{
  "name": "enso-brasil",
  "version": "0.1.0",
  "private": true,
  "description": "Agregador público de alertas climáticos no Brasil.",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fixtures:refresh:inmet": "tsx scripts/refresh-inmet.ts",
    "depcruise": "depcruise --config .dependency-cruiser.cjs src",
    "test": "vitest run",
    "test:ci": "cross-env CI=1 vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "knip": "knip --exclude exports,types,nsExports,nsTypes,enumMembers",
    "prepare": "husky",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "geo:build": "tsx scripts/build-geo.ts"
  },
  "dependencies": {
    "@date-fns/tz": "1.2.0",
    "@neondatabase/serverless": "^1.1.0",
    "@upstash/redis": "^1.37.0",
    "d3-geo": "3.1.1",
    "date-fns": "4.1.0",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "5.3.0",
    "next": "^16",
    "ofetch": "^1.5.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^19",
    "react-dom": "^19",
    "topojson-client": "3.1.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@lhci/cli": "0.14.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/d3-geo": "3.1.0",
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/topojson-client": "3.1.5",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "cross-env": "7.0.3",
    "dependency-cruiser": "^17.3.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^16",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.9.0",
    "lint-staged": "^16.4.0",
    "mapshaper": "0.7.18",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "4.19.2",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "^0.45.2"
    }
  }
}
