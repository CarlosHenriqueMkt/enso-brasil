# ENSO Brasil — exemplo de variáveis de ambiente (P2)
# Copie para .env.local e preencha com credenciais reais. NUNCA commite .env.local.
# Todos os comentários em PT-BR (PROJECT.md: idioma único).

# ---- Banco de dados ----
# Neon Postgres dev branch. Provisionar em https://console.neon.tech (free tier).
# Formato: postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgres://example_user:example_password@ep-example-12345.sa-east-1.aws.neon.tech/enso_dev?sslmode=require

# ---- Cache (Upstash Redis) ----
# Upstash Redis REST. Provisionar em https://console.upstash.com (free tier — 500k cmds/mo).
# As duas variáveis vêm do painel "REST API" do database criado.
UPSTASH_REDIS_REST_URL=https://example-redis-12345.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace_with_upstash_rest_token_from_console

# ---- Token do orquestrador de ingestão ----
# Bearer token consumido por /api/ingest e /api/archive (compare em tempo constante).
# Gerar com: openssl rand -hex 32
# Mesmo valor deve ser configurado no GitHub Actions secrets (INGEST_TOKEN) e na env do Vercel.
INGEST_TOKEN=replace_with_openssl_rand_hex_32_output

# ---- Opcionais ----
# Nível de log do pino (Node runtime). Valores: trace|debug|info|warn|error|fatal. Default: info.
# LOG_LEVEL=debug

# Caminho alternativo para a fixture do stub adapter (relativo à raiz do repo).
# Use para simular cenários nos testes manuais (ex.: tests/fixtures/sources/all-red.json).
# Default: tests/fixtures/sources/stub-default.json
# STUB_FIXTURE_PATH=tests/fixtures/sources/all-red.json

# Connection string do Postgres de testes (docker-compose.test.yml — D-02).
# Apenas necessário ao rodar a suíte de integração localmente.
# DATABASE_URL_TEST=postgres://postgres:postgres@localhost:5433/test
